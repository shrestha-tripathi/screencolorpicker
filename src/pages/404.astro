---
import Layout from "../layouts/Layout.astro";
import { b, site } from "../site.config";
---
<Layout title="404 — Not found" noindex>
  <section class="px-4 sm:px-6 py-24 sm:py-36">
    <div class="mx-auto max-w-md text-center">
      <p class="font-mono text-[12px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-4">Error 404</p>
      <h1 class="heading-display text-[48px] sm:text-[56px] mb-4 text-[var(--color-fg)]">Not found.</h1>
      <p class="text-[16px] text-[var(--color-fg-secondary)] mb-10">
        That page doesn't exist. But your colors do.
      </p>
      <a
        href={b("/")}
        class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-[14px] font-medium bg-[var(--color-fg)] text-[var(--color-bg)] hover:opacity-90 transition-opacity"
      >
        ← Back to {site.name}
      </a>
    </div>
  </section>
</Layout>

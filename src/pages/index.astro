---
import Layout from "../layouts/Layout.astro";
import ColorPicker from "../components/ColorPicker.astro";
import { site } from "../site.config";

// FAQPage JSON-LD — inlined for SEO
const faqs = [
  {
    q: "What is the EyeDropper API?",
    a: "The EyeDropper API is a browser-native feature (Chrome 95+, Edge 95+, Brave, Opera) that turns your cursor into a system-wide color picker. It can sample any pixel visible on your screen — including outside the browser, across multiple monitors. It requires zero permissions and works fully offline.",
  },
  {
    q: "Why doesn't this work in Firefox or Safari?",
    a: "Firefox and Safari haven't shipped the EyeDropper API yet. Mozilla's official position is that they don't plan to implement it; WebKit (Safari) hasn't signaled support either. We recommend using Chrome, Edge, Brave, or Opera. We're considering an image-upload fallback for Firefox/Safari users in a future release.",
  },
  {
    q: "Is ColorTrail really free? What's the catch?",
    a: "100% free, forever. No accounts, no signup, no ads, no upsells. Your colors never leave your device — everything runs locally in your browser. We don't collect, store, or transmit any color data you pick. There is no catch.",
  },
  {
    q: "Can ColorTrail see the colors I pick?",
    a: "No. The EyeDropper API is fully client-side — colors are returned directly to the JavaScript running in your browser, never sent over the network. Your palette history is stored in your browser's localStorage and never leaves your device.",
  },
  {
    q: "What is OKLCH and why should I care?",
    a: "OKLCH is a perceptually uniform color space introduced in 2020 by Björn Ottosson. CSS Color Level 4 (2023+) supports it natively. It produces predictable color manipulations — lightening or darkening a color by the same amount perceptually looks like the same amount of change. Modern design systems (Tailwind v4, OpenProps) increasingly use OKLCH for color tokens. Most online color pickers don't expose OKLCH; we do.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const appJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: site.name,
  url: site.url,
  description: site.tagline,
  applicationCategory: "DesignApplication",
  operatingSystem: "Web Browser (Chromium-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  browserRequirements: "Requires the EyeDropper API (Chrome 95+, Edge 95+, Brave, Opera).",
};
---

<Layout
  title="Free screen color picker — no install, no extensions"
  description="Pick any color from your screen — instantly. Free, in-browser, zero install, zero permissions. HEX, RGB, HSL, OKLCH formats with click-to-copy. Works on Chrome, Edge, Brave, Opera."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- HERO -->
  <section class="px-4 sm:px-6 pt-12 sm:pt-20 pb-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-balance">
        Pick any color from your screen.
        <span class="block mt-2 text-[var(--color-accent)]">Instantly.</span>
      </h1>
      <p class="mt-5 text-lg sm:text-xl text-[var(--color-muted)] text-balance">
        Free. In your browser. Zero install. Zero permissions. Zero tracking.
      </p>
    </div>
  </section>

  <!-- LIVE PICKER -->
  <section class="px-4 sm:px-6 pb-12">
    <div class="mx-auto max-w-5xl">
      <ColorPicker />
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="px-4 sm:px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-3">How it works</h2>
      <p class="text-center text-[var(--color-muted)] mb-12 max-w-2xl mx-auto">
        Three taps. No setup, no learning curve, no friction.
      </p>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)] font-semibold flex items-center justify-center mb-4">1</div>
          <h3 class="text-lg font-semibold mb-2">Click the button</h3>
          <p class="text-sm text-[var(--color-muted)]">
            Tap the big "Pick a color" button at the top. Your cursor instantly turns into a precision eyedropper.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)] font-semibold flex items-center justify-center mb-4">2</div>
          <h3 class="text-lg font-semibold mb-2">Click anywhere</h3>
          <p class="text-sm text-[var(--color-muted)]">
            Click on any pixel — inside the browser, in your IDE, in Photoshop, in a YouTube video, on any monitor. Zoom mode shows pixel-level detail.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)] font-semibold flex items-center justify-center mb-4">3</div>
          <h3 class="text-lg font-semibold mb-2">Copy in any format</h3>
          <p class="text-sm text-[var(--color-muted)]">
            HEX, RGB, HSL, or OKLCH — one click to clipboard. Build up your palette as you go; it's saved locally.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="px-4 sm:px-6 py-16 border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-3">Why ColorTrail?</h2>
      <p class="text-center text-[var(--color-muted)] mb-12 max-w-2xl mx-auto">
        Compared to every other color picker — extensions, native apps, online tools.
      </p>

      <div class="overflow-x-auto -mx-4 sm:mx-0">
        <table class="w-full text-sm border-collapse min-w-[640px]">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left py-3 px-4 font-semibold text-[var(--color-muted)]">&nbsp;</th>
              <th class="text-center py-3 px-4 font-semibold text-[var(--color-accent)]">{site.name}</th>
              <th class="text-center py-3 px-4 font-semibold text-[var(--color-muted)]">ColorZilla</th>
              <th class="text-center py-3 px-4 font-semibold text-[var(--color-muted)]">Sip / ColorSnapper</th>
              <th class="text-center py-3 px-4 font-semibold text-[var(--color-muted)]">Online image pickers</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-fg)]">
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">Cost</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Free forever</td>
              <td class="py-3 px-4 text-center">Free + ads</td>
              <td class="py-3 px-4 text-center">$10–25</td>
              <td class="py-3 px-4 text-center">Free + ads</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">Install required</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">None</td>
              <td class="py-3 px-4 text-center">Extension</td>
              <td class="py-3 px-4 text-center">App</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">None</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">Pick from outside browser</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Yes</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">No</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Yes</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">No</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">Cross-platform</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Win/Mac/Linux</td>
              <td class="py-3 px-4 text-center">Browser-only</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">Mac-only</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Yes</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">Permissions needed</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">None</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">All websites</td>
              <td class="py-3 px-4 text-center">Screen recording</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">None</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 font-medium">OKLCH output</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">Yes</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">No</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">No</td>
              <td class="py-3 px-4 text-center text-[var(--color-error)]">Rarely</td>
            </tr>
            <tr>
              <td class="py-3 px-4 font-medium">Privacy</td>
              <td class="py-3 px-4 text-center text-[var(--color-success)]">100% local</td>
              <td class="py-3 px-4 text-center">Telemetry + ads</td>
              <td class="py-3 px-4 text-center">100% local</td>
              <td class="py-3 px-4 text-center">Uploads file</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-4 sm:px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-10">FAQ</h2>
      <div class="grid gap-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5 open:bg-[var(--color-surface)] transition-colors">
            <summary class="cursor-pointer font-semibold text-base flex items-center justify-between gap-4 list-none">
              <span>{f.q}</span>
              <svg class="w-5 h-5 text-[var(--color-muted)] transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <p class="mt-3 text-[var(--color-muted)] leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="px-4 sm:px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3">
        Stop installing extensions for a color picker.
      </h2>
      <p class="text-[var(--color-muted)] text-balance">
        Bookmark <code class="font-mono text-[var(--color-accent)]">{site.domain}</code> and you're done.
        Press <kbd class="px-2 py-0.5 rounded bg-[var(--color-surface)] border border-[var(--color-border)] font-mono text-sm">P</kbd> anytime to pick.
      </p>
    </div>
  </section>
</Layout>

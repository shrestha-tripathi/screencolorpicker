---
import Layout from "../layouts/Layout.astro";
import ColorPicker from "../components/ColorPicker.astro";
import { site } from "../site.config";

// FAQPage JSON-LD — inlined for SEO
const faqs = [
  {
    q: "What is the EyeDropper API?",
    a: "The EyeDropper API is a browser-native feature (Chrome 95+, Edge 95+, Brave, Opera) that turns your cursor into a system-wide color picker. It can sample any pixel visible on your screen — including outside the browser, across multiple monitors. It requires zero permissions and works fully offline.",
  },
  {
    q: "Why doesn't this work in Firefox or Safari?",
    a: "Firefox and Safari haven't shipped the EyeDropper API yet. Mozilla's official position is that they don't plan to implement it; WebKit (Safari) hasn't signaled support either. We recommend using Chrome, Edge, Brave, or Opera. We're considering an image-upload fallback for Firefox/Safari users in a future release.",
  },
  {
    q: "Is ColorTrail really free? What's the catch?",
    a: "100% free, forever. No accounts, no signup, no ads, no upsells. Your colors never leave your device — everything runs locally in your browser. We don't collect, store, or transmit any color data you pick. There is no catch.",
  },
  {
    q: "Can ColorTrail see the colors I pick?",
    a: "No. The EyeDropper API is fully client-side — colors are returned directly to the JavaScript running in your browser, never sent over the network. Your palette history is stored in your browser's localStorage and never leaves your device.",
  },
  {
    q: "What is OKLCH and why should I care?",
    a: "OKLCH is a perceptually uniform color space introduced in 2020 by Björn Ottosson. CSS Color Level 4 (2023+) supports it natively. It produces predictable color manipulations — lightening or darkening a color by the same amount perceptually looks like the same amount of change. Modern design systems (Tailwind v4, OpenProps) increasingly use OKLCH for color tokens. Most online color pickers don't expose OKLCH; we do.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const appJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: site.name,
  url: site.url,
  description: site.tagline,
  applicationCategory: "DesignApplication",
  operatingSystem: "Web Browser (Chromium-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  browserRequirements: "Requires the EyeDropper API (Chrome 95+, Edge 95+, Brave, Opera).",
};
---

<Layout
  title="Free screen color picker — no install, no extensions"
  description="Pick any color from your screen — instantly. Free, in-browser, zero install, zero permissions. HEX, RGB, HSL, OKLCH formats with click-to-copy. Works on Chrome, Edge, Brave, Opera."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  {/* ===== HERO ===== */}
  <section class="px-4 sm:px-6 pt-16 sm:pt-24 pb-8">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1 rounded-pill text-[12px] font-medium font-mono uppercase tracking-wider"
           style="background-color: var(--color-badge-bg); color: var(--color-badge-fg);">
        <span class="w-1.5 h-1.5 rounded-full" style="background-color: var(--color-badge-fg);"></span>
        Built on window.EyeDropper
      </div>

      <h1 class="heading-display text-[44px] sm:text-[56px] lg:text-[64px] text-balance text-[var(--color-fg)]">
        Pick any color
        <br />
        from your screen.
      </h1>
      <p class="mt-5 text-[18px] sm:text-[20px] leading-[1.6] text-[var(--color-fg-secondary)] max-w-xl mx-auto text-balance">
        Free. In your browser. Zero install, zero permissions, zero tracking.
      </p>
    </div>
  </section>

  {/* ===== LIVE PICKER ===== */}
  <section class="px-4 sm:px-6 pb-20">
    <div class="mx-auto max-w-4xl">
      <ColorPicker />
    </div>
  </section>

  {/* ===== HOW IT WORKS ===== */}
  <section class="px-4 sm:px-6 py-20" style="box-shadow: inset 0 1px 0 var(--color-border);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="eyebrow mb-3">Workflow</p>
        <h2 class="heading-section text-[32px] sm:text-[40px] text-[var(--color-fg)] text-balance">
          Three taps. No setup.
        </h2>
        <p class="mt-4 text-[16px] sm:text-[18px] text-[var(--color-fg-secondary)] max-w-xl mx-auto leading-relaxed">
          From cursor to clipboard in under three seconds.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            num: "01",
            title: "Click the button",
            body: "Tap the dark CTA above. Your cursor instantly turns into a precision eyedropper.",
          },
          {
            num: "02",
            title: "Click anywhere",
            body: "Sample any pixel — your IDE, Photoshop, a YouTube video, another monitor. Zoom mode shows pixel detail.",
          },
          {
            num: "03",
            title: "Copy in any format",
            body: "HEX, RGB, HSL, or OKLCH — one tap to clipboard. Palette saves locally as you build it.",
          },
        ].map((step) => (
          <div
            class="rounded-md p-6"
            style="background-color: var(--color-bg); box-shadow: var(--shadow-card);"
          >
            <p class="font-mono text-[12px] font-medium uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">
              {step.num}
            </p>
            <h3 class="heading-card text-[20px] text-[var(--color-fg)] mb-2">{step.title}</h3>
            <p class="text-[15px] leading-relaxed text-[var(--color-fg-secondary)]">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== COMPARISON ===== */}
  <section class="px-4 sm:px-6 py-20" style="background-color: var(--color-bg-elevated); box-shadow: inset 0 1px 0 var(--color-border), inset 0 -1px 0 var(--color-border);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="eyebrow mb-3">Why {site.name}</p>
        <h2 class="heading-section text-[32px] sm:text-[40px] text-[var(--color-fg)] text-balance">
          Stop installing extensions.
        </h2>
        <p class="mt-4 text-[16px] sm:text-[18px] text-[var(--color-fg-secondary)] max-w-xl mx-auto leading-relaxed">
          The empty intersection: free, cross-platform, zero-permission, screen-wide.
        </p>
      </div>

      <div
        class="overflow-x-auto rounded-lg"
        style="background-color: var(--color-bg); box-shadow: var(--shadow-card);"
      >
        <table class="w-full text-[14px] min-w-[640px]">
          <thead>
            <tr style="box-shadow: inset 0 -1px 0 var(--color-border);">
              <th class="text-left py-4 px-5 eyebrow font-mono text-[12px]">&nbsp;</th>
              <th class="text-center py-4 px-5 font-semibold text-[var(--color-fg)]" style="letter-spacing: -0.01em;">{site.name}</th>
              <th class="text-center py-4 px-5 font-medium text-[var(--color-fg-secondary)]">ColorZilla</th>
              <th class="text-center py-4 px-5 font-medium text-[var(--color-fg-secondary)]">Sip / ColorSnapper</th>
              <th class="text-center py-4 px-5 font-medium text-[var(--color-fg-secondary)]">Online pickers</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-fg)]">
            {[
              { row: "Cost", us: "Free forever", a: "Free + ads", b: "$10–25", c: "Free + ads", usOk: true },
              { row: "Install required", us: "None", a: "Extension", b: "App", c: "None", usOk: true, cOk: true },
              { row: "Pick from outside browser", us: "Yes", a: "No", b: "Yes", c: "No", usOk: true, bOk: true, aBad: true, cBad: true },
              { row: "Cross-platform", us: "Win / Mac / Linux", a: "Browser-only", b: "Mac-only", c: "Yes", usOk: true, cOk: true, bBad: true },
              { row: "Permissions", us: "None", a: "All websites", b: "Screen recording", c: "None", usOk: true, cOk: true, aBad: true },
              { row: "OKLCH output", us: "Yes", a: "No", b: "No", c: "Rarely", usOk: true, aBad: true, bBad: true },
              { row: "Privacy", us: "100% local", a: "Telemetry + ads", b: "100% local", c: "Uploads file", usOk: true, bOk: true, aBad: true, cBad: true },
            ].map((r, idx, arr) => (
              <tr style={`box-shadow: ${idx < arr.length - 1 ? 'inset 0 -1px 0 var(--color-border)' : 'none'};`}>
                <td class="py-3.5 px-5 font-medium">{r.row}</td>
                <td class={`py-3.5 px-5 text-center ${r.usOk ? 'text-[var(--color-success)] font-medium' : ''}`}>{r.us}</td>
                <td class={`py-3.5 px-5 text-center text-[var(--color-fg-secondary)] ${r.aBad ? 'text-[var(--color-error)]' : ''}`}>{r.a}</td>
                <td class={`py-3.5 px-5 text-center text-[var(--color-fg-secondary)] ${r.bOk ? 'text-[var(--color-success)]' : r.bBad ? 'text-[var(--color-error)]' : ''}`}>{r.b}</td>
                <td class={`py-3.5 px-5 text-center text-[var(--color-fg-secondary)] ${r.cOk ? 'text-[var(--color-success)]' : r.cBad ? 'text-[var(--color-error)]' : ''}`}>{r.c}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* ===== FAQ ===== */}
  <section class="px-4 sm:px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">FAQ</p>
        <h2 class="heading-section text-[32px] sm:text-[40px] text-[var(--color-fg)] text-balance">
          Common questions.
        </h2>
      </div>
      <div class="grid gap-3">
        {faqs.map((f) => (
          <details
            class="group rounded-md p-5 transition-colors"
            style="background-color: var(--color-bg); box-shadow: var(--shadow-ring);"
          >
            <summary class="cursor-pointer font-semibold text-[16px] text-[var(--color-fg)] flex items-center justify-between gap-4 list-none" style="letter-spacing: -0.01em;">
              <span>{f.q}</span>
              <svg class="w-4 h-4 text-[var(--color-muted)] transition-transform group-open:rotate-180 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <p class="mt-3 text-[15px] text-[var(--color-fg-secondary)] leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ===== FINAL CTA ===== */}
  <section class="px-4 sm:px-6 py-20" style="box-shadow: inset 0 1px 0 var(--color-border);">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="heading-section text-[28px] sm:text-[36px] text-[var(--color-fg)] text-balance mb-4">
        Bookmark <code class="font-mono text-[var(--color-fg-secondary)]" style="letter-spacing: -0.02em;">{site.domain}</code>.
        <br class="hidden sm:block" />
        You're done.
      </h2>
      <p class="text-[16px] text-[var(--color-fg-secondary)] mb-8">
        Press
        <kbd class="inline-block mx-1 px-2 py-0.5 rounded-md font-mono text-[13px] text-[var(--color-fg)]" style="background-color: var(--color-bg); box-shadow: var(--shadow-ring);">P</kbd>
        anytime to pick.
      </p>
      <a
        href="#picker-root"
        class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-[14px] font-medium bg-[var(--color-fg)] text-[var(--color-bg)] hover:opacity-90 transition-opacity"
      >
        Try it now →
      </a>
    </div>
  </section>
</Layout>

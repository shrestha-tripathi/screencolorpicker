---
import { site, b } from "../site.config";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-border)]
         bg-[var(--color-bg)]/85 backdrop-blur-md"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 h-14 flex items-center justify-between">
    <a
      href={b("/")}
      class="flex items-center gap-2 text-[var(--color-fg)] font-semibold"
      aria-label={`${site.name} home`}
    >
      <svg
        viewBox="0 0 24 24"
        class="w-6 h-6 text-[var(--color-accent)]"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <!-- eyedropper icon -->
        <path d="m2 22 1-1h3l9-9" />
        <path d="M3 21v-3l9-9" />
        <path d="m15 6 3.4-3.4a2.121 2.121 0 1 1 3 3L18 9l.4.4a2.121 2.121 0 1 1-3 3l-3.8-3.8a2.121 2.121 0 1 1 3-3l.4.4Z" />
      </svg>
      <span>{site.name}</span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-3 text-sm">
      <a
        href={b("/about")}
        class="hidden sm:inline-block px-3 py-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)] transition-colors"
      >
        About
      </a>
      <a
        href={b("/privacy")}
        class="hidden sm:inline-block px-3 py-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)] transition-colors"
      >
        Privacy
      </a>
      {site.github && (
        <a
          href={site.github}
          target="_blank"
          rel="noopener"
          class="hidden sm:inline-flex items-center px-3 py-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)] transition-colors"
          aria-label="GitHub repository"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.467-2.38 1.235-3.22-.135-.303-.54-1.52.105-3.17 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.65.24 2.867.12 3.17.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.62-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
      )}
      <ThemeToggle />
    </nav>
  </div>
</header>

---
/**
 * ColorPicker — the main interactive feature.
 *
 * Renders the big CTA button, browser-support banner, active-color result
 * card, palette history strip, and toast container. All behavior lives in
 * ColorPicker.script.ts so the markup stays readable here.
 */
---

<section id="picker-root" class="w-full">
  {/* Browser compatibility banner — JS-controlled visibility */}
  <div
    id="compat-banner"
    class="hidden mx-auto max-w-3xl mb-6 rounded-lg border border-[var(--color-warning)]/40
           bg-[var(--color-warning)]/10 px-4 py-3 text-sm text-[var(--color-fg)]"
    role="status"
    aria-live="polite"
  >
    <p id="compat-banner-text"></p>
  </div>

  {/* Main CTA — the entire reason the user is here */}
  <div class="text-center mb-10">
    <button
      type="button"
      id="pick-btn"
      class="inline-flex items-center justify-center gap-3
             rounded-full px-8 py-5 sm:px-10 sm:py-6
             text-lg sm:text-xl font-semibold
             bg-[var(--color-accent)] text-[var(--color-accent-fg)]
             hover:bg-[var(--color-accent-hover)]
             shadow-lg shadow-[var(--color-accent)]/25
             transition-all duration-150 ease-out
             active:scale-[0.98]
             disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-[var(--color-accent)]"
      aria-label="Pick a color from your screen"
    >
      <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m2 22 1-1h3l9-9" />
        <path d="M3 21v-3l9-9" />
        <path d="m15 6 3.4-3.4a2.121 2.121 0 1 1 3 3L18 9l.4.4a2.121 2.121 0 1 1-3 3l-3.8-3.8a2.121 2.121 0 1 1 3-3l.4.4Z" />
      </svg>
      <span id="pick-btn-label">Pick a color from your screen</span>
    </button>
    <p id="pick-hint" class="mt-3 text-sm text-[var(--color-muted)]">
      Cursor turns into an eyedropper — click anywhere, even outside the browser.
    </p>
  </div>

  {/* Active color result card */}
  <div
    id="result-card"
    class="hidden mx-auto max-w-3xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] overflow-hidden mb-8 shadow-xl"
  >
    <div class="grid sm:grid-cols-[200px_1fr] items-stretch">
      {/* Big swatch */}
      <div
        id="result-swatch"
        class="min-h-[140px] sm:min-h-[200px] flex items-center justify-center font-mono text-sm"
        style="background-color: #6366f1"
      >
        <span id="result-swatch-hex" class="opacity-70">#6366F1</span>
      </div>

      {/* Format list */}
      <div class="p-5 sm:p-6 grid gap-2.5">
        <div class="grid grid-cols-[60px_1fr_auto] items-center gap-3 text-sm">
          <span class="text-[var(--color-muted)] uppercase text-xs tracking-wide">HEX</span>
          <code id="fmt-hex" class="font-mono text-base text-[var(--color-fg)] truncate">#6366F1</code>
          <button type="button" data-copy="hex" class="copy-btn px-3 py-1.5 rounded-md text-xs font-medium bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-fg)] transition-colors" aria-label="Copy HEX">Copy</button>
        </div>
        <div class="grid grid-cols-[60px_1fr_auto] items-center gap-3 text-sm">
          <span class="text-[var(--color-muted)] uppercase text-xs tracking-wide">RGB</span>
          <code id="fmt-rgb" class="font-mono text-base text-[var(--color-fg)] truncate">rgb(99, 102, 241)</code>
          <button type="button" data-copy="rgb" class="copy-btn px-3 py-1.5 rounded-md text-xs font-medium bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-fg)] transition-colors" aria-label="Copy RGB">Copy</button>
        </div>
        <div class="grid grid-cols-[60px_1fr_auto] items-center gap-3 text-sm">
          <span class="text-[var(--color-muted)] uppercase text-xs tracking-wide">HSL</span>
          <code id="fmt-hsl" class="font-mono text-base text-[var(--color-fg)] truncate">hsl(239, 84%, 67%)</code>
          <button type="button" data-copy="hsl" class="copy-btn px-3 py-1.5 rounded-md text-xs font-medium bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-fg)] transition-colors" aria-label="Copy HSL">Copy</button>
        </div>
        <div class="grid grid-cols-[60px_1fr_auto] items-center gap-3 text-sm">
          <span class="text-[var(--color-muted)] uppercase text-xs tracking-wide" title="2023+ designer hotness — perceptually uniform">
            OKLCH
          </span>
          <code id="fmt-oklch" class="font-mono text-base text-[var(--color-fg)] truncate">oklch(58.51% 0.1817 280.3)</code>
          <button type="button" data-copy="oklch" class="copy-btn px-3 py-1.5 rounded-md text-xs font-medium bg-[var(--color-surface)] hover:bg-[var(--color-border)] text-[var(--color-fg)] transition-colors" aria-label="Copy OKLCH">Copy</button>
        </div>
      </div>
    </div>
  </div>

  {/* Palette history strip */}
  <div id="palette-section" class="hidden mx-auto max-w-3xl">
    <div class="flex items-center justify-between mb-3 px-1">
      <h2 class="text-sm font-semibold text-[var(--color-muted)] uppercase tracking-wide">
        Recent palette
        <span id="palette-count" class="ml-1 text-[var(--color-fg-subtle)] font-normal normal-case">(0)</span>
      </h2>
      <button
        type="button"
        id="clear-palette"
        class="text-xs text-[var(--color-muted)] hover:text-[var(--color-error)] transition-colors"
      >
        Clear all
      </button>
    </div>
    <div
      id="palette-grid"
      class="grid grid-cols-8 sm:grid-cols-12 gap-2"
      role="list"
      aria-label="Recent color palette"
    >
      {/* swatches injected by script */}
    </div>
  </div>

  {/* Toast (copy confirmation) */}
  <div
    id="toast"
    class="hidden fixed left-1/2 bottom-8 -translate-x-1/2 z-50
           px-4 py-2.5 rounded-full text-sm font-medium
           bg-[var(--color-fg)] text-[var(--color-bg)]
           shadow-2xl"
    style="animation: toast-in 0.2s ease-out"
    role="status"
    aria-live="polite"
  ></div>
</section>

<script src="./ColorPicker.script.ts"></script>

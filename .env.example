# Copy to .env (gitignored) for local overrides.
# All public vars must start with PUBLIC_ to reach client code.

# Used for canonical URLs, OG meta, sitemap.xml. Cloudflare Pages sets these in
# the dashboard for production. Local default falls through to colortrail.com.
PUBLIC_SITE_URL=https://colortrail.com
PUBLIC_SITE_DOMAIN=colortrail.com

# Brand name shown in nav, footer, OG title. Single source of truth.
PUBLIC_SITE_NAME=ColorTrail
PUBLIC_SITE_SHORT_NAME=ColorTrail
PUBLIC_SITE_TAGLINE=Pick any color from your screen. Free, private, zero install.
PUBLIC_SITE_DESCRIPTION=Pick any color from anywhere on your screen — your IDE, Photoshop, a YouTube video, a PDF, even another monitor. Free, in-browser, zero install. Built on the EyeDropper API.

# Astro base path. "/" for production, "/colortrail/" if hosted under a subpath.
PUBLIC_BASE_PATH=/

# GitHub repo URL (footer link). Leave blank to hide.
PUBLIC_GITHUB_URL=https://github.com/shrestha-tripathi/colortrail

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXX). Leave blank to disable.
PUBLIC_GA4_ID=

# Trust pages — used by About / Contact / Privacy Policy / Terms + JSON-LD.
# All editable without code changes via .env override.
PUBLIC_SITE_AUTHOR=Shrestha Tripathi
PUBLIC_SITE_CONTACT_EMAIL=hello@colortrail.com
PUBLIC_SITE_JURISDICTION=India
PUBLIC_SITE_LOCALE=en
